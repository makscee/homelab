  # {{ ansible_managed }}
  # Phase: private — entire site tailnet-only.
  # Injected inside the *.makscee.ru wildcard block.
  @kuma_host_priv host {{ kuma_public_host }}
  @kuma_tailnet_priv client_ip {{ kuma_tailnet_cidr }}
  handle @kuma_host_priv {
    handle @kuma_tailnet_priv {
      reverse_proxy uptime-kuma:3001
    }
    respond "Forbidden" 403
  }
