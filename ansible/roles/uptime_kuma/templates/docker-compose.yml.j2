# {{ ansible_managed }}
services:
  uptime-kuma:
    image: {{ kuma_image }}
    container_name: uptime-kuma
    restart: unless-stopped
    ports:
      - "{{ kuma_bind_host }}:{{ kuma_bind_port }}:3001"
    volumes:
      - {{ kuma_data_dir }}:/app/data
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:3001"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
