# {{ ansible_managed }}
# HMB-9d — void-mail STAGING runtime environment.
# Rendered to {{ void_staging_compose_dir }}/void-mail-staging/.env (mode 0600).
#
# MOCK_MODE=1 means: in-memory ring buffer + /v1/mail/_mock/last endpoint, no
# real SMTP. SMTP_* vars are intentionally absent — src/index.ts only requires
# them when MOCK_MODE=0.
#
# DATABASE_URL points to the side-car postgres `void-mail-staging-db` defined
# in compose-staging.yml. Required because dbRecorder() is wired
# unconditionally in production wiring (see src/index.ts:33 and
# src/db/index.ts:21).
NODE_ENV=production
PORT=3000
MOCK_MODE=1
DATABASE_URL=postgres://void_mail:void_mail_staging@void-mail-staging-db:5432/void_mail
