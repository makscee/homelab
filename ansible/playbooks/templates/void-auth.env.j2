# {{ ansible_managed }}
# HMB-9b — void-auth runtime environment.
# Rendered to {{ void_stack_dir }}/void-auth/.env (mode 0600) on mcow.
# Non-secret defaults come from group_vars/void_platform.yml; the void-mail
# bearer token (if set) is decrypted from secrets/void-auth.sops.yaml via
# community.sops.load_vars (see playbooks/void-platform-mcow.yml).
NODE_ENV=production
PORT={{ void_auth_port }}

# SQLite DB inside the container; backed by named volume void-auth-data.
DATABASE_URL={{ void_auth_database_url }}

# Public URL for device-authorization verification_uri.
AUTH_PUBLIC_URL={{ void_auth_public_url }}

# void-mail client.
MAIL_BASE_URL={{ void_auth_mail_base_url }}
MAIL_TOKEN={{ void_auth_mail_token }}

# Optional dev seed admin email. Empty in prod = no-op.
SEED_ADMIN_EMAIL={{ void_auth_seed_admin_email }}
