# {{ ansible_managed }}
# VFL-7 — void-fleet runtime environment.
# Rendered to {{ void_stack_dir }}/void-fleet/.env (mode 0600) on mcow.
#
# Non-secret defaults come from group_vars/void_platform.yml; encrypted secrets
# (PROXMOX_TOKEN_ID, PROXMOX_TOKEN_SECRET, DATABASE password) are decrypted from
# secrets/void-fleet.sops.yaml via community.sops.load_vars (see playbooks/void-platform-mcow.yml).
PORT={{ void_fleet_port }}
NODE_ENV=production
MOCK_MODE=0
AUTH_SKIP=1
DATABASE_URL=postgres://{{ void_fleet_db_user }}:{{ vault_fleet_db_pass }}@{{ void_fleet_db_host }}:{{ void_fleet_db_port }}/{{ void_fleet_db_name }}
VOID_AUTH_URL=http://void-auth:{{ void_auth_port }}
AUTH_BASE_URL=http://void-auth:{{ void_auth_port }}
START_WORKER=1
PROXMOX_BASE_URL={{ vault_fleet_proxmox_host }}
PROXMOX_TOKEN_ID={{ vault_fleet_proxmox_token_id }}
PROXMOX_TOKEN_SECRET={{ vault_fleet_proxmox_token_secret }}
PROXMOX_NODE=tower
PROXMOX_CA_PEM=/etc/void-fleet/tower-ca.pem
OPERATOR_SSH_PUBKEY={{ vault_fleet_operator_ssh_pubkey }}
OPERATOR_SSH_PRIVKEY=/run/secrets/operator-ssh-key
LXC_SSH_JUMP_HOST=tower
MCOW_SSH_HOST=mcow
FLEET_SSH_HOST=box.voidnet.makscee.ru