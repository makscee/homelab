# {{ ansible_managed }}
# HMB-9 — void-mail runtime environment.
# Rendered to {{ void_stack_dir }}/void-mail/.env (mode 0600) on mcow.
# Non-secret defaults come from group_vars/void_platform.yml; the SMTP password
# is decrypted from secrets/void-mail.sops.yaml via community.sops.load_vars.
PORT={{ void_mail_port }}
SMTP_HOST={{ void_mail_smtp_host }}
SMTP_PORT={{ void_mail_smtp_port }}
SMTP_USER={{ void_mail_smtp_user }}
SMTP_PASS={{ void_mail_smtp_pass }}
SMTP_FROM_NAME={{ void_mail_smtp_from_name }}
SMTP_FROM_EMAIL={{ void_mail_smtp_from_email }}
