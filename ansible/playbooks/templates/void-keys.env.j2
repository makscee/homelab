# {{ ansible_managed }}
# HMB-9c — void-keys runtime environment.
# Rendered to {{ void_stack_dir }}/void-keys/.env (mode 0600) on mcow.
#
# Non-secret defaults come from group_vars/void_platform.yml; pool tokens are
# NOT in this file — they're decrypted at deploy time by community.sops.load_vars
# from secrets/void-keys-tokens.sops.yaml and rendered as plaintext YAML to
# {{ void_stack_dir }}/void-keys/pool_tokens.yaml on mcow, then mounted into the
# container at {{ void_keys_sops_tokens_file }}. token-store.ts tries `sops -d`
# first; that fails (image has no sops binary) and falls back to plaintext read
# of the same path. The DB password is decrypted from secrets/void-keys.sops.yaml
# via community.sops.load_vars (see playbooks/void-platform-mcow.yml).
#
# Admin auth: void-keys does NOT use ADMIN_TOKEN. Admin endpoints are gated by
# verifyToken (delegates to void-auth /verify) + requireAdmin middleware which
# checks role='admin' on the verified user. No env var needed.
NODE_ENV=production
PORT={{ void_keys_port }}
MOCK_MODE=0

# Postgres (drizzle-orm/postgres-js). Container DNS, void-keys-db sidecar.
DATABASE_URL=postgres://{{ void_keys_db_user }}:{{ void_keys_db_pass }}@{{ void_keys_db_host }}:{{ void_keys_db_port }}/{{ void_keys_db_name }}

# void-auth verify endpoint base URL — verifyToken middleware POSTs to
# `${AUTH_BASE_URL}/verify`. Reaches void-auth by container name on the void net.
AUTH_BASE_URL={{ void_keys_auth_base_url }}

# void-auth admin endpoint base URL. services/user-names polls
# `${AUTH_ADMIN_BASE_URL}/users` every USER_NAMES_REFRESH_SEC to populate a
# userId -> displayName map used as the `userName` Prometheus label on
# voidkeys_usage_* gauges. No app-level auth (compose-network trust boundary).
AUTH_ADMIN_BASE_URL={{ void_keys_auth_admin_base_url }}
USER_NAMES_REFRESH_SEC={{ void_keys_user_names_refresh_sec | default(300) }}

# Pool-tokens YAML path inside the container. Plaintext (decrypted on host at
# deploy time); mounted ro from {{ void_stack_dir }}/void-keys/pool_tokens.yaml.
SOPS_TOKENS_FILE={{ void_keys_sops_tokens_file }}

# Service-to-service auth key. When set, requests with a matching
# x-internal-key header bypass verifyToken and gain admin access.
# Used by void-admin to call /v1/admin/* without a user JWT.
INTERNAL_SERVICE_KEY={{ void_keys_internal_service_key }}

# AES-256-GCM key for encrypting raw tokens at rest (VKE-5). 32-byte binary
# file, generated once on mcow, mounted read-only from the host.
ENCRYPTION_KEY_FILE={{ void_keys_encryption_key_file }}

# claude-key-exporter scrape config (VKE-2 sidecar).
CLAUDE_KEY_EXPORTER_URL={{ void_keys_exporter_url }}
