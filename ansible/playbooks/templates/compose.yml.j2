# {{ ansible_managed }}
# HMB-9 — void platform stack on mcow.
# Rendered to {{ void_stack_dir }}/compose.yml by playbooks/void-platform-mcow.yml.
#
# Edge TLS termination is handled by the Caddy container in this stack
# (migrated off the host-deb caddy 2026-04-29). Caddy reaches host services
# (voidnet-api on 8080, animaya on 8080, homelab-admin on 3847, vibe stack
# on 8081/8083) via host.docker.internal — see Caddyfile.j2.
#
# void-mail is internal-only (no public vhost yet); it'll get one when
# HMB-9b/9c land auth/keys.
---
name: void

networks:
  void:
    driver: bridge

volumes:
  caddy_data: {}
  caddy_config: {}
  caddy_logs: {}  # HMB-18 — admin ACL audit logs persist across container recreate
  void_auth_data: {}
  void_keys_db_data: {}

services:
  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    # Long-form port spec: docker engine 29.x mis-parses short-form "80:80"
    # as HostIP (HostConfig.PortBindings shows {invalid IP 80}, breaks
    # NetworkSettings.Networks attachment). Long-form bypasses the buggy
    # string parser. See HMB-9 Work Log session 4 (2026-04-29).
    ports:
      - target: 80
        published: 80
        host_ip: {{ mcow_public_ip }}
        protocol: tcp
      - target: 443
        published: 443
        host_ip: {{ mcow_public_ip }}
        protocol: tcp
      - target: 443
        published: 443
        host_ip: {{ mcow_public_ip }}
        protocol: udp  # HTTP/3
      # VAD-1 — bind :8443 on tailnet IP only for the admin.makscee.ru:8443
      # listener (public :443 stays for other vhosts). tailscaled owns :443 on
      # the tailnet IP already, so we use :8443 to avoid the conflict.
      - target: 8443
        published: 8443
        host_ip: {{ mcow_tailnet_ip }}
        protocol: tcp
      # VFL-7 — bind :8444 on tailnet IP for void-fleet (fleet.makscee.ru or similar).
      - target: 8444
        published: 8444
        host_ip: {{ mcow_tailnet_ip }}
        protocol: tcp
    extra_hosts:
      # Caddy proxies to host-bound services (voidnet-api :8080, animaya :8080,
      # homelab-admin :3847, vibe :8081/:8083). host.docker.internal resolves
      # via host-gateway. See Caddyfile.j2.
      - "host.docker.internal:host-gateway"
    volumes:
      - {{ void_stack_dir }}/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
      - caddy_logs:/var/log/caddy  # HMB-18 — admin ACL audit log target
    networks:
      - void
    healthcheck:
      test: ["CMD", "caddy", "validate", "--config", "/etc/caddy/Caddyfile"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 10s

  void-mail:
    image: {{ void_mail_image }}
    restart: unless-stopped
    env_file:
      - {{ void_stack_dir }}/void-mail/.env
    networks:
      - void
    # void-mail listens on PORT (default 3000, set in group_vars/void_platform.yml).
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:{{ void_mail_port }}/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    # No `ports:` block — void-mail is internal-only in slice 1 (no public DNS).

  void-auth:
    # HMB-9b — auth service. Image SHA-pinned in group_vars/void_platform.yml
    # (void_auth_image_tag) for deterministic deploy + rollback. Internal-only;
    # Caddy proxies auth.makscee.ru -> void-auth:{{ void_auth_port }} via the
    # void network (see Caddyfile.j2).
    image: {{ void_auth_image }}
    container_name: void-auth
    restart: unless-stopped
    env_file:
      - {{ void_stack_dir }}/void-auth/.env
    expose:
      - "{{ void_auth_port }}"
    volumes:
      - void_auth_data:/data
    depends_on:
      void-mail:
        condition: service_healthy
    networks:
      - void
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:{{ void_auth_port }}/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

  void-keys-db:
    # HMB-9c — postgres for void-keys (drizzle-orm/postgres-js). Internal to
    # the `void` compose network; never published. Mirrors the staging
    # void-mail-staging-db pattern. Credentials from secrets/void-keys.sops.yaml.
    image: postgres:16-alpine
    container_name: void-keys-db
    restart: unless-stopped
    environment:
      POSTGRES_USER: "{{ void_keys_db_user }}"
      POSTGRES_PASSWORD: "{{ void_keys_db_pass }}"
      POSTGRES_DB: "{{ void_keys_db_name }}"
    volumes:
      - void_keys_db_data:/var/lib/postgresql/data
    networks:
      - void
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ void_keys_db_user }} -d {{ void_keys_db_name }}"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 10s

  void-admin:
    # VAD-1 — admin panel (Next.js). Tailnet-only via Caddy ACL (admin.makscee.ru
    # vhost requires remote_ip in 100.64.0.0/10). No public exposure.
    # Depends on void-auth for API calls; no DB of its own.
    image: {{ void_admin_image }}
    container_name: void-admin
    restart: unless-stopped
    environment:
      - VOID_AUTH_URL=http://void-auth:{{ void_auth_port }}
      - VOID_KEYS_URL=http://void-keys:{{ void_keys_port }}
      - VOID_KEYS_INTERNAL_KEY={{ void_keys_internal_service_key }}
      - NODE_ENV=production
    expose:
      - "{{ void_admin_port }}"
    depends_on:
      void-auth:
        condition: service_healthy
      void-keys:
        condition: service_healthy
    networks:
      - void
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:{{ void_admin_port }}/ || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

  void-fleet:
    image: {{ void_fleet_image }}
    container_name: void-fleet
    restart: unless-stopped
    env_file:
      - {{ void_stack_dir }}/void-fleet/.env
    expose:
      - "{{ void_fleet_port }}"
    networks:
      - void
    depends_on:
      void-keys-db:
        condition: service_healthy
      void-auth:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:{{ void_fleet_port }}/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    volumes:
      - {{ void_stack_dir }}/void-fleet/operator-ssh-key:/run/secrets/operator-ssh-key:ro
      - {{ void_stack_dir }}/void-fleet/tower-ca.pem:/etc/void-fleet/tower-ca.pem:ro

  void-keys:
    # HMB-9c — keys service. Pool API token store + sticky user→key binder for
    # claudev. Image SHA-pinned via void_keys_image_tag. Internal-only on the
    # void network; Caddy proxies keys.makscee.ru -> void-keys:{{ void_keys_port }}
    # (see Caddyfile.j2). Pool-tokens YAML is mounted read-only at
    # {{ void_keys_sops_tokens_file }} as PLAINTEXT — decrypted at deploy time
    # by Ansible (community.sops.load_vars) and rendered to the host. The image
    # lacks the sops binary, so runtime `sops -d` falls back to plaintext read.
    image: {{ void_keys_image }}
    container_name: void-keys
    restart: unless-stopped
    env_file:
      - {{ void_stack_dir }}/void-keys/.env
    expose:
      - "{{ void_keys_port }}"
    volumes:
      # Plaintext pool-tokens YAML rendered by playbooks/void-platform-mcow.yml
      # from secrets/void-keys-tokens.sops.yaml. Read-only mount, mode 0600 on
      # host. Never commit the rendered file — it lives only on mcow.
      - {{ void_stack_dir }}/void-keys/pool_tokens.yaml:{{ void_keys_sops_tokens_file }}:ro
      # AES-256-GCM encryption key for token-at-rest (VKE-5). 32-byte binary,
      # generated once on mcow. Never commit — lives only on the host.
      - {{ void_stack_dir }}/void-keys/encryption.key:{{ void_keys_encryption_key_file }}:ro
    extra_hosts:
      # Reach claude-key-exporter on the mcow host (sidecar LXC ships later).
      - "host.docker.internal:host-gateway"
    depends_on:
      void-auth:
        condition: service_healthy
      void-keys-db:
        condition: service_healthy
    networks:
      - void
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:{{ void_keys_port }}/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
