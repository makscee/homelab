# {{ ansible_managed }}
# HMB-9 — void platform stack on mcow.
# Rendered to {{ void_stack_dir }}/compose.yml by playbooks/void-platform-mcow.yml.
#
# Edge TLS termination is handled by the host-native caddy on mcow
# (/etc/caddy/Caddyfile). Slice 1 keeps void-mail internal-only — no public
# vhost is needed yet. HMB-9b/9c will add auth.makscee.ru / keys.makscee.ru
# stanzas to the host caddy and may publish ports here on loopback.
---
name: void

networks:
  void:
    driver: bridge

services:
  void-mail:
    image: {{ void_mail_image }}
    restart: unless-stopped
    env_file:
      - {{ void_stack_dir }}/void-mail/.env
    networks:
      - void
    # void-mail listens on PORT (default 3000, set in group_vars/void_platform.yml).
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:{{ void_mail_port }}/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    # No `ports:` block — void-mail is internal-only in slice 1 (no public DNS).
