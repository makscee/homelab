# {{ ansible_managed }}
# HMB-9d — void-auth STAGING runtime environment.
# Rendered to {{ void_staging_compose_dir }}/void-auth-staging/.env (mode 0600).
#
# SQLite db at /data/void-auth.db (volume void_staging_auth_data).
# MAIL_BASE_URL points at the staging void-mail container by compose DNS name.
# MAIL_TOKEN is empty — MOCK_MODE staging void-mail does not require auth (see
# void-mail spec; staging trust boundary is the compose network).
# SEED_ADMIN_EMAIL is consumed by services/seed.ts on first boot when users
# table is empty: inserts the email as role=admin, emailVerified=true.
NODE_ENV=production
PORT=3000
DATABASE_URL=/data/void-auth.db
AUTH_PUBLIC_URL=https://auth-staging.makscee.ru
MAIL_BASE_URL=http://void-mail-staging:3000
MAIL_TOKEN={{ void_staging_auth_mail_token | default('') }}
SEED_ADMIN_EMAIL={{ void_staging_seed_admin_email }}
COOKIE_DOMAIN=.makscee.ru
