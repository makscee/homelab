# docker-tower env template. Real values never committed. Secrets: see secrets/docker-tower.sops.yaml.
#
# Usage:
#   cp .env.example .env        # fill in real values
#   sops --decrypt --output-type dotenv ../../secrets/docker-tower.sops.yaml > /run/secrets/grafana.env
#   docker compose -f docker-compose.monitoring.yml up -d
#
# Non-secret placeholders only — secrets live in secrets/docker-tower.sops.yaml (Grafana admin user/password).

# Selects which Prometheus config file to mount into the prometheus container.
# Defaults to prometheus.yml if unset (see docker-compose.monitoring.yml).
PROMETHEUS_CONFIG=prometheus.yml
