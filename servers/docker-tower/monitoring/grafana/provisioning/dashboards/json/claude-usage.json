  "panels": [
    {
      "title": "5-Hour Utilization",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto",
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "claude_usage_5h_utilization",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
