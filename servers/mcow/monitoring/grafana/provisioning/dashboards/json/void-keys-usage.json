{
  "uid": "void-keys-usage",
  "title": "void-keys Usage",
  "tags": [
    "void-keys",
    "usage",
    "homelab"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "schemaVersion": 39,
  "editable": false,
  "graphTooltip": 0,
  "style": "dark",
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "user",
        "label": "User",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-homelab"
        },
        "query": {
          "query": "label_values(voidkeys_usage_input_tokens_total, userName)",
          "refId": "user"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-homelab"
        },
        "query": {
          "query": "label_values(voidkeys_usage_input_tokens_total, model)",
          "refId": "model"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "name",
        "label": "Pool Key",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-homelab"
        },
        "query": "label_values(claude_usage_5h_utilization, name)",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "table",
      "title": "Per-key utilization",
      "description": "Mirrors statusline `5h:N%±Δ/left  7d:N%±Δ/left`. Δ = used% − elapsed%. Negative Δ = behind pace (can spend more), positive = ahead (slow down).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-homelab"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "claude_usage_5h_utilization{name=~\"$name\"} * 100",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "(claude_usage_5h_utilization{name=~\"$name\"} - on(name) clamp_max(clamp_min(1 - (claude_usage_5h_reset_timestamp{name=~\"$name\"} - time())/18000, 0), 1)) * 100",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "clamp_min(claude_usage_5h_reset_timestamp{name=~\"$name\"} - time(), 0)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "claude_usage_7d_utilization{name=~\"$name\"} * 100",
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "(claude_usage_7d_utilization{name=~\"$name\"} - on(name) clamp_max(clamp_min(1 - (claude_usage_7d_reset_timestamp{name=~\"$name\"} - time())/604800, 0), 1)) * 100",
          "format": "table",
          "instant": true
        },
        {
          "refId": "F",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "clamp_min(claude_usage_7d_reset_timestamp{name=~\"$name\"} - time(), 0)",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {"id": "merge"},
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "name": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6
            },
            "renameByName": {
              "name": "key",
              "Value #A": "5h %",
              "Value #B": "5h Δ",
              "Value #C": "5h left",
              "Value #D": "7d %",
              "Value #E": "7d Δ",
              "Value #F": "7d left"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "5h left"},
            "properties": [
              {"id": "unit", "value": "dtdhms"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "7d left"},
            "properties": [
              {"id": "unit", "value": "dtdhms"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "5h %"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 80}
              ]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "7d %"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 80}
              ]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "5h Δ"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-text"}},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [
                {"color": "super-light-green", "value": null},
                {"color": "green", "value": -15},
                {"color": "yellow", "value": -5},
                {"color": "orange", "value": 5},
                {"color": "red", "value": 15}
              ]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "7d Δ"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-text"}},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [
                {"color": "super-light-green", "value": null},
                {"color": "green", "value": -15},
                {"color": "yellow", "value": -5},
                {"color": "orange", "value": 5},
                {"color": "red", "value": 15}
              ]}}
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {"displayName": "5h %", "desc": true}
        ]
      }
    },
    {
      "id": 103,
      "title": "Per-key 5h utilization over time",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-homelab"
          },
          "expr": "claude_usage_5h_utilization{name=~\"$name\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 104,
      "title": "Per-key 7d utilization over time",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
