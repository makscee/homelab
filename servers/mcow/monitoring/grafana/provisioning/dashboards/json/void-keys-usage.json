    },
    {
      "id": 2,
      "title": "Per-user breakdown",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-homelab"
          },
          "expr": "sum by (userName) ({__name__=~\"voidkeys_usage_(input|output)_tokens_total\", userName=~\"$user\", model=~\"$model\"})",
          "legendFormat": "{{userName}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Per-model breakdown",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
