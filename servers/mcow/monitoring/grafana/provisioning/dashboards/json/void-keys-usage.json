      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "claude_usage_7d_utilization{name=~\"$name\"} - on(name) clamp_max(clamp_min(1 - (claude_usage_7d_reset_timestamp{name=~\"$name\"} - time())/604800, 0), 1)",
          "legendFormat": "{{name}}"
