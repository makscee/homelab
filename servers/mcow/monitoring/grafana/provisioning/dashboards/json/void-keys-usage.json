{
  "uid": "void-keys-usage",
  "title": "void-keys Usage",
  "tags": [
    "void-keys",
    "usage",
    "homelab"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "schemaVersion": 39,
  "editable": false,
  "graphTooltip": 0,
  "style": "dark",
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "user",
        "label": "User",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-homelab"
        },
        "query": {
          "query": "label_values(voidkeys_usage_input_tokens_total, userId)",
          "refId": "user"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-homelab"
        },
        "query": {
          "query": "label_values(voidkeys_usage_input_tokens_total, model)",
          "refId": "model"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "name",
        "label": "Pool Key",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-homelab"
        },
        "query": "label_values(claude_usage_5h_utilization, name)",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "gauge",
      "title": "Per-key 5h utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-homelab"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-homelab"
          },
          "expr": "claude_usage_5h_utilization{name=~\"$name\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "red",
                "value": 0.8
              }
            ]
          }
        },
        "overrides": []
      }
    },
