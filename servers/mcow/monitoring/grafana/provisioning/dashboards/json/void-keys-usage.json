      "targets": [
        {
          "refId": "Input",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-homelab"
          },
          "expr": "sum(voidkeys_usage_input_tokens_total{userName=~\"$user\", model=~\"$model\"})",
          "legendFormat": "Input"
        },
        {
          "refId": "Output",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-homelab"
          },
          "expr": "sum(voidkeys_usage_output_tokens_total{userName=~\"$user\", model=~\"$model\"})",
          "legendFormat": "Output"
