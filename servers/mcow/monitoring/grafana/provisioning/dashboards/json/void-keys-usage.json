          },
          "expr": "claude_usage_7d_utilization{name=~\"$name\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 105,
      "title": "Per-key 5h pace deviation",
      "type": "timeseries",
      "description": "utilization − time-elapsed fraction. 0 = on pace, negative = behind (can catch up), positive = ahead (slow down).",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "thresholdsStyle": {"mode": "line"}
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus-homelab"},
          "expr": "claude_usage_5h_utilization{name=~\"$name\"} - on(name) clamp_max(clamp_min(1 - (claude_usage_5h_reset_timestamp{name=~\"$name\"} - time())/18000, 0), 1)",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 106,
      "title": "Per-key 7d pace deviation",
      "type": "timeseries",
      "description": "utilization − time-elapsed fraction over 7d window. 0 = on pace, negative = behind, positive = ahead.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
