{
  "uid": "homelab-mobile",
  "title": "Homelab Mobile",
  "description": "Mobile-optimized glance dashboard — single column, phone-friendly",
  "tags": ["homelab", "mobile"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 39,
  "version": 3,
  "panels": [
    {
      "id": 30,
      "title": "VPN (AmneziaWG)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Connected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "awg_peers_connected",
          "legendFormat": "clients online",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "title": "Total Peers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "awg_peers_total",
          "legendFormat": "configured",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "title": "Clients",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "username" },
            "properties": [
              { "id": "displayName", "value": "User" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #RX" },
            "properties": [
              { "id": "displayName", "value": "RX" },
              { "id": "unit", "value": "decbytes" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #TX" },
            "properties": [
              { "id": "displayName", "value": "TX" },
              { "id": "unit", "value": "decbytes" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #HS" },
            "properties": [
              { "id": "displayName", "value": "Last seen" },
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "text", "value": null },
                  { "color": "green", "value": -180000 }
                ]
              }},
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Last seen", "desc": true }],
        "cellHeight": "sm",
        "frameIndex": 0
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "awg_peer_transfer_rx_bytes{allowed_ip!=\"(none)\",username!=\"unknown\"}",
          "legendFormat": "",
          "refId": "RX",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "awg_peer_transfer_tx_bytes{allowed_ip!=\"(none)\",username!=\"unknown\"}",
          "legendFormat": "",
          "refId": "TX",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "awg_peer_last_handshake_seconds{allowed_ip!=\"(none)\",username!=\"unknown\"} * 1000",
          "legendFormat": "",
          "refId": "HS",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "allowed_ip" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "public_key": true,
              "public_key 1": true,
              "public_key 2": true,
              "username 1": true,
              "username 2": true,
              "allowed_ip": true
            },
            "indexByName": {
              "username": 0,
              "Value #HS": 1,
              "Value #RX": 2,
              "Value #TX": 3
            }
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              { "targetField": "Value #HS", "destinationType": "time" }
            ]
          }
        }
      ]
    },
    {
      "id": 34,
      "title": "VPN Traffic (amn0)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "axisBorderShow": false
          },
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "TX" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "rate(node_network_receive_bytes_total{job=\"node\",instance=~\"100.101.0.3.*\",device=\"amn0\"}[5m])",
          "legendFormat": "RX",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "rate(node_network_transmit_bytes_total{job=\"node\",instance=~\"100.101.0.3.*\",device=\"amn0\"}[5m])",
          "legendFormat": "TX",
          "refId": "B"
        }
      ]
    },
    {
      "id": 1,
      "title": "Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Hosts Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "green", "value": 6 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "count(up{job=\"node\"} == 1)",
          "legendFormat": "hosts up",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Containers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "count(container_last_seen{job=\"cadvisor\",name!=\"\",name!=\"cadvisor\"})",
          "legendFormat": "running",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU %",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "(1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"node\"}[5m]))) * on(instance) group_left(nodename) node_uname_info{job=\"node\"}",
          "legendFormat": "{{ nodename }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "RAM %",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"})) * on(instance) group_left(nodename) node_uname_info{job=\"node\"}",
          "legendFormat": "{{ nodename }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Disk %",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "((node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} - node_filesystem_avail_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"}) / node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"}) * on(instance) group_left(nodename) node_uname_info{job=\"node\"}",
          "legendFormat": "{{ nodename }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Containers",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Top Containers by CPU",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "topk(7, rate(container_cpu_usage_seconds_total{job=\"cadvisor\",name!=\"\",name!=\"cadvisor\"}[5m]))",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top Containers by RAM",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "topk(7, container_memory_rss{job=\"cadvisor\",name!=\"\",name!=\"cadvisor\"})",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Network",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 58 },
      "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true,
            "axisBorderShow": false
          },
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*TX.*" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "rate(node_network_receive_bytes_total{job=\"node\",device!~\"lo|veth.*|br.*|docker.*|tailscale.*\"}[5m]) * on(instance) group_left(nodename) node_uname_info{job=\"node\"}",
          "legendFormat": "RX {{ nodename }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-homelab" },
          "expr": "rate(node_network_transmit_bytes_total{job=\"node\",device!~\"lo|veth.*|br.*|docker.*|tailscale.*\"}[5m]) * on(instance) group_left(nodename) node_uname_info{job=\"node\"}",
          "legendFormat": "TX {{ nodename }}",
          "refId": "B"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
