voidnet.makscee.ru {
  # Phase 7 / Pitfall 5: strip client-supplied CGNAT header on public block.
  # Only tailnet-bound listeners may set x-tailscale-ip (from {client_ip}).
  request_header -X-Tailscale-Ip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
  }

  handle_path /jellyfin/* {
    reverse_proxy 100.101.0.8:8096
  }
  handle /jellyfin {
    redir /jellyfin/ permanent
  }
  handle /navidrome* {
    reverse_proxy 100.101.0.8:4533
  }

  # claude-key installer scripts (/install/claude-key/<code>/{sh,ps1}) -> axum on mcow
  handle /install/* {
    reverse_proxy 100.101.0.9:8080
  }

  # axum JSON API + health
  handle /api/* {
    reverse_proxy 100.101.0.9:8080
  }
  handle /health {
    reverse_proxy 100.101.0.9:8080
  }

  # axum auth form POSTs — Next portal renders GETs for /login /join /profile,
  # but the <form> submits POST to these paths which only exist on axum:8080.
  @axum_auth_forms {
    method POST
    path /join/submit /join/verify /login/email /login/verify /login/telegram /logout /profile/email /profile/email/verify /profile/link/telegram /profile/invite /profile/unlink/* /profile/boosty /profile/boosty/unlink
  }
  handle @axum_auth_forms {
    reverse_proxy 100.101.0.9:8080
  }

  # Next.js (everything else: landing, /login, /join, /dashboard, /services/*,
  # /admin/* gated by Next middleware via x-tailscale-ip → 403 when absent).
  handle {
    reverse_proxy 100.101.0.9:3848
  }
}


animaya.makscee.ru {
  encode zstd gzip
  reverse_proxy 100.101.0.9:8080 {
    header_up Host {host}
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-For {remote_host}
    flush_interval -1
    transport http {
      read_timeout 0
      write_timeout 0
    }
  }
}
