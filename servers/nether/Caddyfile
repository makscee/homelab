voidnet.makscee.ru {
  # Phase 7 / Pitfall 5: strip client-supplied CGNAT header on public block.
  # Only tailnet-bound listeners may set x-tailscale-ip (from {client_ip}).
  request_header -X-Tailscale-Ip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
  }

  handle_path /jellyfin/* {
    reverse_proxy 100.101.0.8:8096
  }
  handle /jellyfin {
    redir /jellyfin/ permanent
  }
  handle /navidrome* {
    reverse_proxy 100.101.0.8:4533
  }

  # claude-key installer scripts (/install/claude-key/<code>/{sh,ps1}) -> axum on mcow
  handle /install/* {
    reverse_proxy 100.101.0.9:8080
  }

  # axum JSON API + health
  handle /api/* {
    reverse_proxy 100.101.0.9:8080
  }
  handle /health {
    reverse_proxy 100.101.0.9:8080
  }

  # axum auth form POSTs — Next portal renders GETs for /login /join /profile,
  # but the <form> submits POST to these paths which only exist on axum:8080.
  @axum_auth_forms {
    method POST
    path /join/submit /join/verify /login/email /login/verify /login/telegram /logout /profile/email /profile/email/verify /profile/link/telegram /profile/invite /profile/unlink/* /profile/boosty /profile/boosty/unlink
  }
  handle @axum_auth_forms {
    reverse_proxy 100.101.0.9:8080
  }

  # Next.js (everything else: landing, /login, /join, /dashboard, /services/*,
  # /admin/* gated by Next middleware via x-tailscale-ip → 403 when absent).
  handle {
    reverse_proxy 100.101.0.9:3848
  }
}


animaya.makscee.ru {
  encode zstd gzip
  reverse_proxy 100.101.0.9:8080 {
    header_up Host {host}
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-For {remote_host}
    flush_interval -1
    transport http {
      read_timeout 0
      write_timeout 0
    }
  }
}

# admin.makscee.ru — tailnet-gated admin face for voidnet portal + admin API.
# VDN-21. Source-IP gate: Tailscale CGNAT only (100.64.0.0/10) — same trust
# boundary as ssh. Non-allowed sources get 403 (admin is API+UI; honest 403
# beats a redirect to a page they also can't reach).
# X-Tailscale-Ip is injected from the real client IP after the gate accepts;
# Next.js middleware on mcow reads it to admit /admin/* routes.
# Route split (Plan B — admin listener only mounts /admin/*):
#   /api/admin/* → voidnet-api admin listener on 100.101.0.9:8081
#   /api/*, /health → voidnet-api public listener on 100.101.0.9:8080
#   everything else → voidnet-web (Next.js) on 100.101.0.9:3848
# Spec: docs/superpowers/specs/2026-04-24-vdn-21-admin-portal-gate-design.md
admin.makscee.ru {
  @cgnat remote_ip 100.64.0.0/10

  handle @cgnat {
    handle /api/admin/* {
      reverse_proxy 100.101.0.9:8081 {
        header_up X-Tailscale-Ip {http.request.remote.host}
      }
    }
    handle /api/* {
      reverse_proxy 100.101.0.9:8080 {
        header_up X-Tailscale-Ip {http.request.remote.host}
      }
    }
    handle /health {
      reverse_proxy 100.101.0.9:8080 {
        header_up X-Tailscale-Ip {http.request.remote.host}
      }
    }
    handle {
      reverse_proxy 100.101.0.9:3848 {
        header_up X-Tailscale-Ip {http.request.remote.host}
      }
    }
  }

  handle {
    respond "forbidden" 403
  }
}
