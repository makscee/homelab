# nether env template. Secrets: secrets/nether.sops.yaml and secrets/nether-awg.sops.yaml.
# Populate by running:
#   sops --decrypt ../../secrets/nether.sops.yaml | awk -F': ' '/^[A-Z]/{gsub(/"/,"",$2); print $1"="$2}' > .env
# Never commit the resulting .env (it's in .gitignore via pattern `.env`).

# Grafana admin (docker-compose.monitoring.yml)
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=

# CouchDB admin (docker-compose.services.yml)
COUCHDB_USER=
COUCHDB_PASSWORD=

# Optional: override prometheus.yml filename (docker-compose.monitoring.yml)
# PROMETHEUS_CONFIG=prometheus.yml
