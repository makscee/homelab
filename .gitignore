# Secrets
.env
*.key
*.pem

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Claude Code agent worktrees (per-task scratch, never commit)
.claude/worktrees/

# Backups
*.bak
*.backup

# Playwright
.playwright-mcp/

# SOPS decrypted outputs (never commit plaintext)
secrets/*.yaml
!secrets/*.sops.yaml

# age key material
*.age
keys.txt

# SOPS temp files
*.sops.yaml.tmp

# Decrypted secrets at runtime — never commit plaintext outputs of sops --decrypt
/run/secrets/
**/run/secrets/

# Ansible
ansible/collections/
ansible/*.retry

# v3.0 Next.js admin app
node_modules
apps/*/node_modules
apps/*/.next
apps/*/.turbo
apps/*/next-env.d.ts
apps/*/.env.local
apps/*/.env.*.local
apps/*/tsconfig.tsbuildinfo
